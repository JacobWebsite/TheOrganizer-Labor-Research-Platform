{
  "category": "healthcare",
  "provision_classes": ["health_insurance"],
  "heading_signals": [
    {"pattern": "\\b(health|medical|insurance|benefits|welfare|dental|vision|prescription)\\b", "weight": 0.3},
    {"pattern": "\\b(health\\s+(and|&)\\s+welfare)\\b", "weight": 0.4},
    {"pattern": "\\b(health\\s+care|healthcare)\\b", "weight": 0.4},
    {"pattern": "\\binsurance\\s+benefits\\b", "weight": 0.35}
  ],
  "text_patterns": [
    {
      "name": "employer_premium",
      "pattern": "(?:employer|company|management)\\s+(?:shall|will|agrees?\\s+to)\\s+(?:pay|contribute|provide|maintain).*(?:premium|health|medical|insurance|coverage)",
      "confidence": 0.85,
      "provision_class": "health_insurance",
      "summary": "Employer health insurance contribution"
    },
    {
      "name": "employee_contribution",
      "pattern": "(?:employee|worker|member)\\s+(?:shall|will|must)?\\s*(?:contribute|pay|share).*(?:premium|cost|health|medical|insurance)",
      "confidence": 0.85,
      "provision_class": "health_insurance",
      "summary": "Employee health insurance contribution"
    },
    {
      "name": "coverage_tiers",
      "pattern": "(?:individual|single|employee[- ]only|family|employee\\s*\\+\\s*(?:spouse|child|dependent))(?=.{0,100}(?:plan|coverage|premium|enrollment|tier|dependent|deductible|copay|coinsurance|HMO|PPO|health\\s+fund|benefit\\s+fund|medical|dental|vision|prescription))",
      "confidence": 0.75,
      "provision_class": "health_insurance",
      "summary": "Health coverage tier definition"
    },
    {
      "name": "hmo_ppo",
      "pattern": "\\b(?:HMO|PPO|EPO|high[- ]deductible|HDHP|preferred\\s+provider)\\b",
      "confidence": 0.80,
      "provision_class": "health_insurance",
      "summary": "Health plan type"
    },
    {
      "name": "copay_deductible",
      "pattern": "\\b(?:co-?pay|copayment|deductible|out[- ]of[- ]pocket|coinsurance)\\b.*\\$\\d+",
      "confidence": 0.85,
      "provision_class": "health_insurance",
      "summary": "Copay/deductible amount"
    },
    {
      "name": "dental_vision",
      "pattern": "\\b(?:dental|vision|optical|orthodonti[ca])\\s+(?:plan|coverage|benefit|insurance|care)",
      "confidence": 0.80,
      "provision_class": "health_insurance",
      "summary": "Dental/vision coverage"
    },
    {
      "name": "prescription_drug",
      "pattern": "\\b(?:prescription|drug|pharmacy|formulary|rx|pharmaceutical)\\s+(?:plan|coverage|benefit|card|co-?pay)",
      "confidence": 0.80,
      "provision_class": "health_insurance",
      "summary": "Prescription drug coverage"
    },
    {
      "name": "opt_out_waiver",
      "pattern": "(?:opt[- ]out|waiver|decline|buyout|cash\\s+in\\s+lieu).*(?:health|medical|insurance|coverage|benefit)",
      "confidence": 0.80,
      "provision_class": "health_insurance",
      "summary": "Health insurance opt-out/waiver"
    },
    {
      "name": "retiree_health",
      "pattern": "\\b(?:retir(?:ee|ement)|post[- ]employment)\\s+(?:health|medical|insurance|benefit|coverage)",
      "confidence": 0.85,
      "provision_class": "health_insurance",
      "summary": "Retiree health benefits"
    },
    {
      "name": "health_fund",
      "pattern": "(?:health|welfare|benefit)\\s+(?:fund|trust|plan).*(?:\\$[\\d,.]+|per\\s+hour|per\\s+month|per\\s+capita)",
      "confidence": 0.85,
      "provision_class": "health_insurance",
      "summary": "Health fund contribution"
    },
    {
      "name": "waiting_period",
      "pattern": "(?:waiting|eligibility)\\s+period.*(?:health|medical|insurance|coverage|benefit|day|month)",
      "confidence": 0.75,
      "provision_class": "health_insurance",
      "summary": "Health insurance waiting period"
    }
  ],
  "negative_patterns": [
    {"pattern": "\\b(?:health\\s+and\\s+safety|safety\\s+and\\s+health|occupational\\s+safety)\\b", "note": "OSHA/safety, not insurance"},
    {"pattern": "\\bmental\\s+health\\s+(?:day|leave|time\\s+off)\\b", "note": "Leave provision, not insurance"},
    {"pattern": "\\bindividual\\b(?=.{0,50}(?:attorney|locker|arbitration|claim|settle|negotiate|superintendent|plaintiff|protocol|death))(?!.{0,50}(?:plan|coverage|premium|tier|enrollment))", "note": "Fix 2: individual in non-health context"},
    {"pattern": "\\bfamily\\s+leave\\b", "note": "Fix 2: family leave is leave, not health tier"},
    {"pattern": "\\bdeath\\s+in\\s+(?:the\\s+)?family\\b", "note": "Fix 2: bereavement, not health tier"}
  ]
}
