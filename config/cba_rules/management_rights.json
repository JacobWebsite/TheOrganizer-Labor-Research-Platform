{
  "category": "management_rights",
  "provision_classes": ["management_rights_clause", "management_enumerated", "operational_discretion", "not_limited_to"],
  "heading_signals": [
    {"pattern": "\\bmanagement\\s+rights\\b", "weight": 0.5},
    {"pattern": "\\b(?:employer|management)\\s+(?:rights|prerogatives|authority)\\b", "weight": 0.4},
    {"pattern": "\\breserved\\s+rights\\b", "weight": 0.3}
  ],
  "text_patterns": [
    {
      "name": "management_rights_clause",
      "pattern": "(?:employer|management|company)\\s+(?:retains|reserves|shall\\s+(?:have|retain))\\s+(?:the\\s+)?(?:exclusive\\s+)?(?:right|authority|prerogative)",
      "confidence": 0.90,
      "provision_class": "management_rights_clause",
      "summary": "Management rights clause"
    },
    {
      "name": "management_enumerated",
      "pattern": "(?:right|authority)\\s+to\\s+(?:hire|fire|direct|assign|transfer|promote|demote|discipline|discharge|determine|establish|maintain|schedule|subcontract)",
      "confidence": 0.80,
      "provision_class": "management_enumerated",
      "summary": "Enumerated management rights"
    },
    {
      "name": "operational_discretion",
      "pattern": "\\b(?:determine|direct|control|manage)\\s+(?:the\\s+)?(?:operations?|workforce|business|methods?|means?)\\b",
      "confidence": 0.75,
      "provision_class": "operational_discretion",
      "summary": "Operational discretion"
    },
    {
      "name": "not_limited_to",
      "pattern": "(?:including\\s+but\\s+not\\s+limited\\s+to).*(?:hire|fire|direct|assign|transfer|promote)",
      "confidence": 0.80,
      "provision_class": "not_limited_to",
      "summary": "Non-exhaustive management rights list"
    }
  ],
  "negative_patterns": [
    {"pattern": "\\bunion.*right\\b", "note": "Union rights, not management"}
  ],
  "heading_exclusions": [
    {"pattern": "\\b(discharge|discipline|disciplinary|dismissal)\\b", "note": "should be job_security"},
    {"pattern": "\\b(just\\s+cause|progressive\\s+discipline)\\b", "note": "discipline standards are job_security"},
    {"pattern": "\\b(scheduling|hours|overtime|shift)\\b", "note": "scheduling articles"},
    {"pattern": "\\b(safety|health\\s+and\\s+safety|OSHA)\\b", "note": "safety articles"},
    {"pattern": "\\b(leave|vacation|sick|holiday|PTO)\\b", "note": "leave articles"}
  ]
}
