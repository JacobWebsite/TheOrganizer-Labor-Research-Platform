{
  "category": "leave",
  "provision_classes": ["vacation_accrual", "vacation_days", "sick_leave", "personal_days", "holiday_list", "holiday_pay", "bereavement", "fmla", "parental_leave", "union_leave", "jury_duty", "military_leave"],
  "heading_signals": [
    {"pattern": "\\b(vacation|sick\\s+leave|personal\\s+(?:day|leave)|holiday|bereavement|leave\\s+of\\s+absence)\\b", "weight": 0.35},
    {"pattern": "\\b(paid\\s+time\\s+off|PTO|annual\\s+leave)\\b", "weight": 0.35},
    {"pattern": "\\b(FMLA|family\\s+(?:and\\s+)?medical\\s+leave|parental\\s+leave)\\b", "weight": 0.4}
  ],
  "text_patterns": [
    {
      "name": "vacation_accrual",
      "pattern": "\\b(?:vacation|annual\\s+leave|PTO)\\s+(?:shall\\s+)?(?:accrue|earn|be\\s+(?:entitled|granted|credited))\\s*(?:at\\s+(?:the\\s+)?rate\\s+of)?",
      "confidence": 0.85,
      "provision_class": "vacation_accrual",
      "summary": "Vacation accrual"
    },
    {
      "name": "vacation_days",
      "pattern": "(?:\\d+|one|two|three|four|five|six)\\s+(?:weeks?|days?)\\s+(?:of\\s+)?(?:paid\\s+)?vacation",
      "confidence": 0.85,
      "provision_class": "vacation_days",
      "summary": "Vacation days allotment"
    },
    {
      "name": "sick_leave",
      "pattern": "\\bsick\\s+(?:leave|time|days?)\\s+(?:shall|will|may)?\\s*(?:be|accrue|earn)",
      "confidence": 0.85,
      "provision_class": "sick_leave",
      "summary": "Sick leave provision"
    },
    {
      "name": "personal_days",
      "pattern": "\\b(?:personal)\\s+(?:day|leave|holiday)s?\\b",
      "confidence": 0.80,
      "provision_class": "personal_days",
      "summary": "Personal days"
    },
    {
      "name": "holiday_list",
      "pattern": "(?:following|recognized|observed|paid)\\s+holidays?.*(?:New\\s+Year|Martin\\s+Luther|President|Memorial|Independence|Labor\\s+Day|Thanksgiving|Christmas)",
      "confidence": 0.90,
      "provision_class": "holiday_list",
      "summary": "Holiday list"
    },
    {
      "name": "holiday_pay",
      "pattern": "\\bholiday\\s+(?:pay|premium|rate|compensation)\\b.{5,}(?:shall|will|paid|receive|entitled|time\\s+and\\s+(?:a\\s+)?half|double|straight|regular\\s+rate|\\$\\d)",
      "confidence": 0.85,
      "provision_class": "holiday_pay",
      "summary": "Holiday pay"
    },
    {
      "name": "bereavement",
      "pattern": "\\b(?:bereavement|funeral|death\\s+in\\s+(?:the\\s+)?(?:immediate\\s+)?family)\\s+(?:leave|days?|time)",
      "confidence": 0.85,
      "provision_class": "bereavement",
      "summary": "Bereavement leave"
    },
    {
      "name": "fmla",
      "pattern": "\\b(?:FMLA|Family\\s+(?:and\\s+)?Medical\\s+Leave\\s+Act)\\b.{5,}(?:shall|will|entitled|eligible|provide|request|granted|twelve|12|unpaid|qualifying|serious\\s+health)",
      "confidence": 0.85,
      "provision_class": "fmla",
      "summary": "FMLA provision"
    },
    {
      "name": "parental_leave",
      "pattern": "\\b(?:parental|maternity|paternity|adoption|child\\s*(?:birth|rearing|bonding))\\s+leave\\b",
      "confidence": 0.85,
      "provision_class": "parental_leave",
      "summary": "Parental leave"
    },
    {
      "name": "union_leave",
      "pattern": "\\b(?:union|organization)\\s+(?:leave|business|time\\s+off)\\b.*(?:attend|convention|meeting|training|negotiate)",
      "confidence": 0.80,
      "provision_class": "union_leave",
      "summary": "Union leave"
    },
    {
      "name": "jury_duty",
      "pattern": "\\b(?:jury\\s+duty|jury\\s+service)\\b.{5,}(?:shall|will|paid|receive|regular\\s+(?:pay|rate|wages)|difference|excuse|absent|day|serve|summon|proof)",
      "confidence": 0.85,
      "provision_class": "jury_duty",
      "summary": "Jury duty leave"
    },
    {
      "name": "military_leave",
      "pattern": "\\b(?:military|USERRA|armed\\s+forces|National\\s+Guard)\\s+(?:leave|duty|service)\\b",
      "confidence": 0.85,
      "provision_class": "military_leave",
      "summary": "Military leave"
    }
  ],
  "negative_patterns": [
    {"pattern": "\\bleave\\s+(?:of|the)\\s+(?:premises|building|work\\s+area)\\b", "note": "Physical leaving, not time off"},
    {"pattern": "(?:wages|hours|sick\\s+pay|vacations?|holidays?|insurance|relief\\s+periods?),?\\s*(?:,|and)?\\s*(?:jury\\s+duty|holiday\\s+pay|FMLA),?\\s*(?:,|or|and)?\\s*(?:group\\s+life|insurance|sick\\s+pay|vacations?|holidays?)", "note": "Topic in a list of many items = maintenance of standards clause, not standalone leave provision"},
    {"pattern": "\\d{1,3}(?:,\\s*\\d{1,3}){2,}", "note": "Index page numbers like '61, 69, 70'"},
    {"pattern": "compensatory\\s+time|comp\\s+time|fiscal\\s+year\\s+accrual", "note": "Compensatory time language, not military leave"},
    {"pattern": "seniority\\s+(?:list|roster|order|shall\\s+be\\s+(?:defined|determined))", "note": "Seniority definition, not military leave"},
    {"pattern": "(?:following|recognized|observed|designated)\\s+holidays?\\s*:?\\s*(?:New\\s+Year|Martin|President|Memorial|Independence|Labor\\s+Day|Thanksgiving|Christmas)", "note": "Holiday list context, not personal days"}
  ],
  "heading_exclusions": [
    {"pattern": "\\b(enforcement|penalty|penalties|fine)\\b", "note": "enforcement sections"},
    {"pattern": "\\b(overtime|scheduling|hours\\s+of\\s+work|compensation|wages|seniority)\\b", "note": "military leave should not match in scheduling/wages/seniority headings"}
  ]
}
