{
  "category": "training",
  "provision_classes": ["training_program", "tuition_reimbursement", "certification_pay", "apprentice_ratio", "training_time_paid"],
  "heading_signals": [
    {"pattern": "\\b(training|apprentice|education|tuition|professional\\s+development)\\b", "weight": 0.4},
    {"pattern": "\\b(certification|license|continuing\\s+education)\\b", "weight": 0.3}
  ],
  "text_patterns": [
    {
      "name": "training_program",
      "pattern": "(?:employee|employees|worker|workers|staff|personnel)\\s+(?:shall|will|must|may|are\\s+required)?\\s*(?:to\\s+)?(?:attend|complete|participate\\s+in|undergo).*\\b(?:training|instruction)\\b|\\b(?:instruction\\s+or\\s+training|training\\s+(?:program|course)\\s+(?:for|required|provided\\s+to)\\s+(?:employee|worker))",
      "confidence": 0.80,
      "provision_class": "training_program",
      "summary": "Training program"
    },
    {
      "name": "tuition_reimbursement",
      "pattern": "\\b(?:tuition|educational)\\s+(?:reimbursement|assistance|aid|benefit|allowance|waiver)\\b",
      "confidence": 0.85,
      "provision_class": "tuition_reimbursement",
      "summary": "Tuition reimbursement"
    },
    {
      "name": "certification_pay",
      "pattern": "\\b(?:certification|license|credential)\\s+(?:pay|differential|premium|reimbursement|renewal)\\b",
      "confidence": 0.80,
      "provision_class": "certification_pay",
      "summary": "Certification pay/reimbursement"
    },
    {
      "name": "apprentice_ratio",
      "pattern": "\\b(?:apprentice|trainee)\\s+(?:to\\s+)?(?:journeyman|journey\\s*worker)\\s+ratio\\b",
      "confidence": 0.85,
      "provision_class": "apprentice_ratio",
      "summary": "Apprentice ratio"
    },
    {
      "name": "apprentice_ratio_reverse",
      "pattern": "\\bratio\\s+of\\s+apprentices?\\s+to\\s+(?:journeymen|journey\\s*workers?|maintainers?|mechanics?|workers?)\\b|\\bnumber\\s+of\\s+apprentices?\\b.{0,40}\\bratio\\b",
      "confidence": 0.85,
      "provision_class": "apprentice_ratio",
      "summary": "Apprentice ratio (ratio-of phrasing)"
    },
    {
      "name": "training_time_paid",
      "pattern": "\\b(?:training|in-service)\\s+(?:time|hours?)\\s+(?:shall\\s+be\\s+)?(?:paid|compensated|on\\s+(?:company|employer)\\s+time)",
      "confidence": 0.80,
      "provision_class": "training_time_paid",
      "summary": "Paid training time"
    },
    {
      "name": "training_time_paid_required",
      "pattern": "\\b(?:training|orientation|in[\\s\\-]service|safety\\s+training)\\b.{0,100}?\\b(?:shall|will|must)\\s+be\\s+(?:paid|compensated|on\\s+(?:paid|company|employer)\\s+time)\\b",
      "confidence": 0.78,
      "provision_class": "training_time_paid",
      "summary": "Paid training (training will be paid)"
    },
    {
      "name": "training_on_paid_time",
      "pattern": "\\btraining\\b.{0,60}?\\bon\\s+(?:paid|company|employer)\\s+time\\b|\\btraining\\b.{0,40}?\\bcompleted\\s+on\\s+paid\\s+time\\b",
      "confidence": 0.80,
      "provision_class": "training_time_paid",
      "summary": "Training on paid time"
    }
  ],
  "negative_patterns": [
    {"pattern": "\\bTraining\\s+Fund\\b(?!.{0,40}(?:attend|complete|participate|program\\s+for\\s+employee))", "note": "Fix 4: Training Fund as a fund name, not a training provision"},
    {"pattern": "\\bUnion\\s+shall\\s+provide\\s+training\\b.*\\bto\\s+the\\s+Employer\\b", "note": "Fix 4: Union training employers, not employee training"},
    {"pattern": "\\bPension,?\\s+Health,?.*Training\\s+Fund\\s+contributions\\b", "note": "Fix 4: Fund listing, not training provision"}
  ],
  "heading_exclusions": []
}
