DB_HOST=localhost
DB_PORT=5432
DB_NAME=olms_multiyear
DB_USER=postgres
DB_PASSWORD=change_me

# API auth/security
# Generate a strong random value: python -c "import secrets; print(secrets.token_urlsafe(48))"
LABOR_JWT_SECRET=change_me_to_a_long_random_secret
# Auth is ENABLED by default. Uncomment ONLY for local development without login:
# DISABLE_AUTH=true
# Uncomment ONLY if you need admin endpoints without auth (never in production):
# ALLOW_INSECURE_ADMIN=true

# CORS and API throttling
# Comma-separated origins for browser clients.
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:8001
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Matching tuning
MATCH_MIN_NAME_SIM=0.65

# Research agent / external providers
GOOGLE_API_KEY=
OPENAI_API_KEY=
LANGEXTRACT_API_KEY=
RESEARCH_AGENT_MODEL=gemini-2.5-flash
RESEARCH_AGENT_MAX_TURNS=25
RESEARCH_AGENT_MAX_TOKENS=65536
RESEARCH_CACHE_HOURS=168
RESEARCH_SCRAPER_GOOGLE_FALLBACK=true

# SEC ingestion
SEC_USER_AGENT=LaborDataProject/1.0 (contact@example.com)
